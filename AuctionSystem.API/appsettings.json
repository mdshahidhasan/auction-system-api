{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=auction_system;User Id=root;Password=your_password;"
  },
  "Jwt": {
    "Issuer": "AuctionSystem",
    "Audience": "AuctionSystem.Client",
    "Key": "replace-with-a-long-secure-key-at-least-32-characters",
    "AccessTokenMinutes": 60,
    "RememberMeDays": 30,
    "PasswordResetTokenMinutes": 15,
    "EmailVerificationTokenMinutes": 1440
